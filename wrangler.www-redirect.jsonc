{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ravencourt-www-redirect",
  "main": "workers/www-redirect.ts",
  "compatibility_date": "2026-07-22",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "www.ravencourtcapital.com/*",
      "zone_name": "ravencourtcapital.com"
    }
  ]
}
